;; 1. Based on: run33
;; 2. Description: PK Basic model QC FIX_add
;; x1. Author: DUXACT
;; 3. Label:
$PROBLEM   
$INPUT      C ID CYCLE DAY=DROP TIME NTIME=DROP DV AMT RATE DUR CMT
            DOSE MDV EVID BQL TYPE STUDY SEX WT AGE
$DATA      NM_dat_new.csv IGNORE=C
$SUBROUTINE ADVAN3 TRANS4
$PK
D1=DUR
CL = THETA(1) * EXP(ETA(1)) 
V1 = THETA(2) * EXP(ETA(2))
Q  = THETA(3) * EXP(ETA(3))
V2 = THETA(4) * EXP(ETA(4))
S1 = V1/1000 ; AMT unit:mg ; V output unit: L ; DV unit:ng/mL

$ERROR
IPRED = F
    W = SQRT(THETA(5)**2*IPRED**2 + THETA(6)**2)
    Y = IPRED + W*EPS(1)
 IRES = DV-IPRED
IWRES = IRES/W

$THETA  (0,0.0122) ; CL_L/h
 (0,4.36) ; V1_L
 (0,0.0207) ; Q_L/h
 (0,2) ; V2_L
 (0,0.141) ; Prop.RE (sd)
 0 FIX ; Add.RE (sd)
$OMEGA  0.222  ;     IIV CL
 0.0521  ;     IIV V1
 0  FIX  ;      IIV Q
 0  FIX  ;     IIV V2
$SIGMA  1  FIX  ; Proportional error PK
$ESTIMATION METHOD=1 INTER MAXEVAL=9999 NOABORT SIG=3 PRINT=10
; Xpose
$COVARIANCE
$TABLE      ID TIME DV MDV PRED IPRED CWRES CIWRES STUDY ONEHEADER
            NOPRINT NOAPPEND FILE=SDTAB38 FORMAT=s1PE14.7
$TABLE      ID CL V1 Q V2 ETA1 ETA2 ETA3 ETA4 NOPRINT NOAPPEND
            ONEHEADER FILE=PATAB38
$TABLE      ID ETA1 ETA2 ETA3 ETA4 FIRSTONLY NOAPPEND NOPRINT
            FILE=00038.ETA
$TABLE      ID WT SEX STUDY NOPRINT NOAPPEND ONEHEADER FILE=CATAB38
$TABLE      ID AGE NOPRINT NOAPPEND ONEHEADER FILE=COTAB38

  
NM-TRAN MESSAGES 
  
 WARNINGS AND ERRORS (IF ANY) FOR PROBLEM    1
             
 (WARNING  2) NM-TRAN INFERS THAT THE DATA ARE POPULATION.
  
