$PROBLEM
;; 1. Based on: run38
;; 2. Description: Final model QC FIX_add
;; x1. Author: DUXACT
;; 3. Label:


$INPUT C ID CYCLE DAY=DROP TIME NTIME=DROP DV AMT RATE DUR CMT DOSE MDV EVID BQL TYPE STUDY SEX WT AGE

$DATA /Users/grahamju/Desktop/AutoPMX/PopPK_Agent/NM_dat_new.csv IGNORE=C

$SUBROUTINES ADVAN3 TRANS4

$PK
;;; V1WT-DEFINITION START
   V1WT = ((WT/62.14)**THETA(7))
;;; V1WT-DEFINITION END

;;; V1-RELATION START
V1COV=V1WT
;;; V1-RELATION END


D1=DUR
TVCL = THETA(1)
CL = TVCL * EXP(ETA(1)) 
TVV1 = THETA(2)

TVV1 = V1COV*TVV1
V1 = TVV1 * EXP(ETA(2))
TVQ = THETA(3)
Q  = TVQ * EXP(ETA(3))
TVV2 = THETA(4)
V2 = TVV2 * EXP(ETA(4))
S1 = V1/1000

$ERROR
IPRED = F
    W = SQRT(THETA(5)**2*IPRED**2 + THETA(6)**2)
    Y = IPRED + W*EPS(1)
 IRES = DV-IPRED
IWRES = IRES/W

$THETA
(0, 0.0122) ; CL_L/h
(0, 4.36) ; V1_L
(0, 0.0207) ; Q_L/h
(0, 2) ; V2_L
(0, 0.141) ; Prop.RE (sd)
(0) FIX ; Add.RE (sd)
(0,0.73) ; V1WT1

$OMEGA
 0.222 ; IIV CL
 0.0521 ; IIV V1
 0 FIX  ; IIV Q
 0 FIX  ; IIV V2

$SIGMA
 1 FIX  ; Proportional error PK

$EST METHOD=1 INTER MAXEVAL=9999 NOABORT SIG=3 PRINT=10
$COV

; Xpose
$TABLE ID TIME DV MDV PRED IPRED CWRES CIWRES STUDY ONEHEADER NOPRINT NOAPPEND FILE=SDTAB41 FORMAT=s1PE14.7
$TABLE ID CL V1 Q V2 ETA1 ETA2 ETA3 ETA4 NOPRINT NOAPPEND ONEHEADER FILE=PATAB41
$TABLE ID ETA1 ETA2 ETA3 ETA4 FIRSTONLY NOAPPEND NOPRINT FILE=00041.ETA
$TABLE ID WT SEX STUDY NOPRINT NOAPPEND ONEHEADER FILE=CATAB41
$TABLE ID AGE NOPRINT NOAPPEND ONEHEADER FILE=COTAB41
