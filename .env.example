# PopPK Agent 环境配置示例
# 复制此文件为 .env 并填写实际值

# LLM后端选择: lmstudio | ollama | openai | claude | claude_code | codex
POPPK_LLM_BACKEND=lmstudio

# LLM API地址
POPPK_LLM_BASE_URL=http://localhost:1234/v1

# API密钥 (LM Studio用"lm-studio", OpenAI用实际key)
POPPK_LLM_API_KEY=lm-studio

# 模型ID
POPPK_LLM_MODEL_ID=google/gemma-4-26b-a4b

# 视觉模型ID (如果与文本模型不同, 用于GOF/VPC图像判读)
# POPPK_LLM_VISION_MODEL_ID=google/gemma-4-26b-a4b

# 温度参数 (0=确定性, 1=创造性)
POPPK_LLM_TEMPERATURE=0.1

# 最大Token数
POPPK_LLM_MAX_TOKENS=4000

# NONMEM路径 (根据实际安装位置修改)
# POPPK_NONMEM_PATH=/usr/local/bin/nm74
# POPPK_PSN_PATH=/usr/local/bin/vpc
